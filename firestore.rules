rules_version = '2';

service cloud.firestore {
	match /databases/{database}/documents {
		function isSignedIn() {
			return request.auth != null;
		}

		function isSelf(userId) {
			return isSignedIn() && request.auth.uid == userId;
		}

		function assignmentDoc(assignmentId) {
			return get(/databases/$(database)/documents/assignments/$(assignmentId));
		}

		function isTeacherOfAssignment(assignmentId) {
			return isSignedIn()
				&& exists(/databases/$(database)/documents/assignments/$(assignmentId))
				&& assignmentDoc(assignmentId).data.teacherId == request.auth.uid;
		}

		match /users/{userId} {
			allow read, create, update: if isSelf(userId);
			allow delete: if false;
		}

		match /assignments/{assignmentId} {
			allow read: if isSignedIn();
			allow create: if isSignedIn() && request.resource.data.teacherId == request.auth.uid;
			allow update, delete: if isSignedIn() && resource.data.teacherId == request.auth.uid;
		}

		match /submissions/{submissionId} {
			allow read: if isSignedIn()
				&& (
					resource.data.studentId == request.auth.uid
					|| isTeacherOfAssignment(resource.data.assignmentId)
				);

			allow create: if isSignedIn() && request.resource.data.studentId == request.auth.uid;

			allow update: if isSignedIn()
				&& (
					resource.data.studentId == request.auth.uid
					|| isTeacherOfAssignment(resource.data.assignmentId)
				);

			allow delete: if false;
		}
	}
}
