{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the system (teacher or student)",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["teacher", "student"] },
        "createdAt": { "type": "number" }
      },
      "required": ["uid", "name", "email", "role", "createdAt"]
    },
    "Assignment": {
      "title": "Assignment",
      "description": "An assignment created by a teacher",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "teacherId": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "title", "content", "teacherId", "createdAt"]
    },
    "Submission": {
      "title": "Submission",
      "description": "A student's submission for an assignment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "assignmentId": { "type": "string" },
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "content": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "submitted", "graded"] },
        "grade": { "type": "string" },
        "feedback": { "type": "string" },
        "updatedAt": { "type": "number" }
      },
      "required": ["id", "assignmentId", "studentId", "studentName", "content", "status", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Users collection"
    },
    "/assignments/{assignmentId}": {
      "schema": { "$ref": "#/entities/Assignment" },
      "description": "Assignments collection"
    },
    "/submissions/{submissionId}": {
      "schema": { "$ref": "#/entities/Submission" },
      "description": "Submissions collection"
    }
  }
}
